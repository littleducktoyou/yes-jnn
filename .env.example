# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.
#
# To get these values:
#   1. Create a project at https://supabase.com
#   2. Go to Project Settings → API
#   3. Copy the Project URL and anon/public key

SUPABASE_PROJECT_ID=your_project_id_here
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here
SUPABASE_URL=https://your_project_id_here.supabase.co

VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here
VITE_SUPABASE_URL=https://your_project_id_here.supabase.co

# ------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY is required for server-side admin routes.
# NEVER commit this key — set it only in your hosting platform's
# environment variable dashboard (e.g. Lovable Cloud, Cloudflare).
# ------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
